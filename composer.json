{
	"name": "static-export-wp/static-export-wp",
	"description": "Export your WordPress site as static HTML files.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.3",
		"matthiasmullie/minify": "^1.3"
	},
	"require-dev": {
		"phpunit/phpunit": "^11.0",
		"wp-coding-standards/wpcs": "^3.0",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"yoast/phpunit-polyfills": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"StaticExportWP\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"StaticExportWP\\Tests\\": "tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"test": "phpunit",
		"phpcs": "phpcs",
		"phpcbf": "phpcbf"
	}
}
